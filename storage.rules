rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Admin authority comes from Firebase Auth custom claims (set by the
    // server's ADMIN_EMAILS sync), matching firestore.rules. This avoids
    // trusting a Firestore document that could drift out of sync.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isFactionImageAdmin() {
      return isAdmin();
    }

    function canWriteFactionImage() {
      return isFactionImageAdmin()
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    function canWriteCyberJoustSprite() {
      return isAdmin()
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    // Legacy flat paths kept for deletes of older uploads.
    match /factionImages/{imageFile} {
      allow read: if true;
      allow write: if canWriteFactionImage();
      allow delete: if isFactionImageAdmin();
    }

    match /factionImages/{slug}/{imageFile} {
      allow read: if true;
      allow write: if canWriteFactionImage();
      allow delete: if isFactionImageAdmin();
    }

    // Cyber Joust body/weapon sprites generated from the admin Asset Generator.
    match /cyber-joust/{spriteFile=**} {
      allow read: if true;
      allow write: if canWriteCyberJoustSprite();
      allow delete: if isAdmin();
    }
  }
}
