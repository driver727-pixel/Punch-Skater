# Firebase – create a project at https://console.firebase.google.com
# Enable Email/Password (and optionally Google) in Authentication → Sign-in method
# Create a Firestore database in Native mode
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Image generation (Fal.ai) ────────────────────────────────────────────────
# Sign up at https://fal.ai and create an API key.
#
# OPTION A — Direct access (exposes key to the browser, fine for local dev):
#   VITE_FAL_KEY=your_fal_ai_key_here
#
# OPTION B — Backend proxy (recommended for production):
#   1. Deploy server/index.js and set FAL_KEY on the host.
#   2. Point the front-end at the deployed proxy:
#        VITE_IMAGE_API_URL=https://your-server.onrender.com/api/generate-image
#
#   For local development, start the proxy with:
#        FAL_KEY=your_key npm start
#   Then set:
#        VITE_IMAGE_API_URL=/api/generate-image
#   The Vite dev server proxy (vite.config.ts) forwards /api/* to localhost:3001.

VITE_FAL_KEY=
VITE_IMAGE_API_URL=
