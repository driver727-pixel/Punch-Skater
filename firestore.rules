rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Email fields written by clients must match the verified Firebase Auth
    // token. Otherwise a player could claim another player's email and hijack
    // Stripe purchase syncs or trade-recipient lookups keyed by emailLower.
    function authEmail() {
      return ('email' in request.auth.token) ? request.auth.token.email : '';
    }

    function writesVerifiedEmail() {
      return request.resource.data.get('email', '') == authEmail();
    }

    function writesVerifiedEmailLower() {
      return request.resource.data.get('emailLower', '') == authEmail().lower();
    }

    function keepsOrVerifiesEmailFields() {
      return (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['email'])
          || writesVerifiedEmail())
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['emailLower'])
          || writesVerifiedEmailLower());
    }

    // ── Per-user cards ───────────────────────────────────────────────────────
    match /users/{uid}/cards/{cardId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.admin == true);
    }

    // ── Per-user decks ───────────────────────────────────────────────────────
    match /users/{uid}/decks/{deckId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.admin == true);
    }

    // ── Per-user workshop boards ─────────────────────────────────────────────
    match /users/{uid}/workshopBoards/{boardId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.admin == true);
    }

    // ── Per-user collection reward claim receipts ────────────────────────────
    // Claims are granted only by trusted server routes. Players can read their
    // receipts but cannot mint cosmetic rewards or reroll tokens from the client.
    match /users/{uid}/rewardClaims/{claimId} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.admin == true);
      allow create, update, delete: if false;
    }

    // ── Private user profiles ────────────────────────────────────────────────
    // Full profile docs are owner/admin readable only. Admin authority comes
    // from Firebase Auth custom claims, not from self-editable Firestore data.
    match /userProfiles/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.admin == true);
      allow create: if request.auth != null && (
        (request.auth.uid == uid
          && request.resource.data.keys().hasOnly([
            'uid', 'email', 'emailLower', 'displayName', 'discoveredFactions', 'updatedAt'
          ])
          && writesVerifiedEmail()
          && writesVerifiedEmailLower())
        || request.auth.token.admin == true
      );
      allow update: if request.auth != null && (
        (request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'email', 'emailLower', 'displayName', 'discoveredFactions', 'updatedAt'
          ])
          && keepsOrVerifiesEmailFields())
        || request.auth.token.admin == true
      );
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Public user lookup (trade/address book) ──────────────────────────────
    // Minimal directory used for recipient lookup during trades. Individual
    // docs may be fetched by ID, but listing is blocked so the collection
    // cannot be scraped as a sitewide email directory.
    match /userLookup/{uid} {
      allow get: if request.auth != null;
      allow list: if request.auth != null && request.auth.token.admin == true;
      allow create: if request.auth != null && (
        (request.auth.uid == uid
          && request.resource.data.keys().hasOnly(['uid', 'emailLower', 'displayName', 'updatedAt'])
          && writesVerifiedEmailLower())
        || request.auth.token.admin == true
      );
      allow update: if request.auth != null && (
        (request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'emailLower', 'displayName', 'updatedAt'
          ])
          && keepsOrVerifiesEmailFields())
        || request.auth.token.admin == true
      );
      allow delete: if request.auth != null && (
        request.auth.uid == uid || request.auth.token.admin == true
      );
    }

    // ── Image cache ──────────────────────────────────────────────────────────
    // Stores fal.ai-generated image URLs keyed by layer seed so repeated
    // requests for the same parameters never hit fal.ai again.
    // Authenticated users may read or create a cache entry; updates are blocked.
    // Prompt/seed metadata are intentionally excluded from the shared cache.
    match /imageCache/{cacheKey} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['imageUrl', 'createdAt'])
        && request.resource.data.imageUrl is string
        && (
          request.resource.data.imageUrl.matches('https://([a-z0-9-]+\\.)*fal\\.media(/.*)?$')
          || request.resource.data.imageUrl.matches('https://firebasestorage\\.googleapis\\.com(/.*)?$')
          || request.resource.data.imageUrl.matches('https://storage\\.googleapis\\.com(/.*)?$')
        );
      allow update: if false;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Trades ───────────────────────────────────────────────────────────────
    // Both parties can read; trade creation is server-only so economy metadata is
    // authored from persisted card/trade history instead of trusting the client.
    // Only the recipient can update status (accept/decline),
    // and the offerer can cancel a pending trade.
    match /trades/{tradeId} {
      function validTradeStatusUpdate(nextStatus) {
        return resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'updatedAt', 'confirmations'
          ])
          && request.resource.data.status == nextStatus
          && request.resource.data.updatedAt is string
          && (!request.resource.data.keys().hasAny(['confirmations'])
            || request.resource.data.confirmations is map);
      }

      allow read: if request.auth != null && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
      allow create: if false;
      allow update: if request.auth != null && (
        // Recipient accepts/declines
        (request.auth.uid == resource.data.toUid
          && (validTradeStatusUpdate('accepted') || validTradeStatusUpdate('declined'))) ||
        // Offerer cancels while still pending
        (request.auth.uid == resource.data.fromUid
          && validTradeStatusUpdate('cancelled'))
      );
      // Trades cannot be deleted so accepted, declined, and cancelled offers retain an audit trail.
      allow delete: if false;
    }
    // ── Referral Claims ──────────────────────────────────────────────────────
    // Written by an authenticated visitor who arrives via a referral link.
    // Doc ID format: {referrerUid}_{visitorUid}
    // - Only a signed-in visitor may create a claim, so referral credit is
    //   one-per-account: the visitorKey must equal the caller's own uid and the
    //   deterministic doc ID prevents the same account from claiming a referrer
    //   more than once.
    // - Self-referral is blocked: the visitor cannot be the referrer.
    // - Only the referrer (authenticated) may read their own claims.
    match /referralClaims/{claimId} {
      allow read: if request.auth != null
        && resource.data.referrerUid == request.auth.uid;
      allow create: if false;
      allow update, delete: if false;
    }

    // ── Battle Arena ─────────────────────────────────────────────────────────
    // Public arena listings.  Deck stats are NOT stored here — only metadata
    // (name, card count) so opponents cannot see private stats.
    // Any signed-in user can read all entries; only the owner can write/delete.
    match /arena/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── Battle Results ───────────────────────────────────────────────────────
    // Any participant can read their own results; writes are server-only.
    match /battleResults/{resultId} {
      allow read:  if request.auth != null && (
        resource.data.challengerUid == request.auth.uid ||
        resource.data.defenderUid == request.auth.uid
      );
      allow create, update, delete: if false;
    }

    // ── Race Arena: Challenges ───────────────────────────────────────────────
    // RaceChallenge docs. Both participants can read; all writes are server-only
    // (the /api/race/* routes own all challenge state transitions).
    match /challenges/{challengeId} {
      allow read: if request.auth != null && (
        resource.data.challengerUid == request.auth.uid ||
        resource.data.defenderUid == request.auth.uid
      );
      allow create, update, delete: if false;
    }

    // ── Race Arena: Races ────────────────────────────────────────────────────
    // Resolved race timelines. Both participants can read for replay; writes
    // are server-only.
    match /races/{raceId} {
      allow read: if request.auth != null && (
        resource.data.challengerUid == request.auth.uid ||
        resource.data.defenderUid == request.auth.uid
      );
      allow create, update, delete: if false;
    }

    // ── Notifications inbox ──────────────────────────────────────────────────
    // Per-user inbox. Owner-readable; mark-as-read updates are owner-allowed
    // and restricted to the `read` boolean field. Creates are server-only.
    match /notifications/{uid}/items/{notifId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if request.auth != null && request.auth.uid == uid;
      allow create: if false;
    }

    // ── Leaderboard ──────────────────────────────────────────────────────────
    // Public lifetime leaderboard entries keyed by uid.
    // Any signed-in user may read all entries; writes are server-only so scores
    // are recomputed from saved decks instead of trusting client payloads.
    match /leaderboard/{uid} {
      allow read:  if request.auth != null;
      allow create, update, delete: if false;
    }

    // Seasonal leaderboard entries are also server-authored.  Season metadata
    // and entries are readable by signed-in players, but clients cannot mint
    // ranks, bypass cooldowns, or submit scores for another uid.
    match /leaderboardSeasons/{seasonId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;

      match /entries/{uid} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }
    }
    // ── Faction images ───────────────────────────────────────────────────────
    // Stores the uploaded background image URL for each faction (keyed by
    // a sanitized faction slug).  Anyone may read; only admins may write.
      match /factionImages/{factionKey} {
      allow read: if true;
      allow write, delete: if request.auth != null
        && request.auth.token.admin == true;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // New collections — read-only stubs (Sprint 0)
    // Client reads allowed for authenticated users; all writes are server-only
    // until the corresponding feature passes QA and the flag is enabled.
    // ══════════════════════════════════════════════════════════════════════════

    // ── Daily Streaks ────────────────────────────────────────────────────────
    // Per-user daily login streak. Doc ID = uid.
    match /dailyStreaks/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    // ── Missions ─────────────────────────────────────────────────────────────
    // Per-user mission board documents. Owners may read their own contracts and
    // mission-run state. All writes are server-only (client create/update/delete blocked).
    match /missions/{missionId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ── Battle Pass ──────────────────────────────────────────────────────────
    // Per-user battle pass tier + XP state. Doc ID = uid.
    match /battlePass/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    // ── Crews ────────────────────────────────────────────────────────────────
    // Player crew / guild. Any authed user can browse; writes are server-only.
    match /crews/{crewId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // ── Ranked Seasons ───────────────────────────────────────────────────────
    // Season config + standings. Any authed user can read.
    match /rankedSeasons/{seasonId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // ── Wallets ──────────────────────────────────────────────────────────────
    // Per-user Ozzies balance summary with a read-only ledger subcollection.
    // Clients may read their own wallet state, but all writes are API/server-only.
    match /wallets/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update, delete: if false;

      match /ledger/{entryId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create, update, delete: if false;
      }
    }

    // ── Free Forge ───────────────────────────────────────────────────────────
    // Per-account record of the free tier's one-complimentary-card forge and its
    // cooldown. Owners may read their own status, but the cooldown is recorded by
    // the trusted /api/forge/* routes so clearing localStorage cannot mint extra
    // free cards.
    match /freeForge/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    // ── Share Links ──────────────────────────────────────────────────────────
    // Publicly viewable card / deck share links.
    match /shareLinks/{linkId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // Joustur Skatur™ collections — all writes are server-only (Admin SDK).
    // Clients may read only their own documents or documents they participate in.
    // ══════════════════════════════════════════════════════════════════════════

    // ── Joustur Lineups ───────────────────────────────────────────────────────
    // One doc per uid, keyed by uid.  Only the owner may read; server writes.
    match /jousturLineups/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    // ── Joustur Challenges ────────────────────────────────────────────────────
    // Challenger and defender may read their own pending challenges.
    // All state transitions (accept / decline) go through server routes.
    match /jousturChallenges/{challengeId} {
      allow read: if request.auth != null && (
        resource.data.challengerUid == request.auth.uid ||
        resource.data.defenderUid  == request.auth.uid
      );
      allow create, update, delete: if false;
    }

    // ── Joustur Matches ───────────────────────────────────────────────────────
    // Both participants may read the match document.  All game-state mutations
    // (roll, move, win detection, rewards) are server-only.
    match /jousturMatches/{matchId} {
      allow read: if request.auth != null && (
        resource.data.challengerUid == request.auth.uid ||
        resource.data.defenderUid  == request.auth.uid
      );
      allow create, update, delete: if false;

      // Turn log sub-collection — both participants may read for replay.
      match /turns/{turnId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/jousturMatches/$(matchId)).data.challengerUid == request.auth.uid ||
          get(/databases/$(database)/documents/jousturMatches/$(matchId)).data.defenderUid  == request.auth.uid
        );
        allow create, update, delete: if false;
      }
    }

    // ── Joustur Queue ─────────────────────────────────────────────────────────
    // Players may read only their own queue entry.  Enqueue / dequeue is
    // handled server-side so the matchmaking transaction cannot be bypassed.
    match /jousturQueue/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

  }
}
